{
  "name": "epoch-quiz-server",
  "version": "1.0.0",
  "description": "Epoch Quiz backend — Node.js + TypeScript + Prisma + MySQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx prisma/seed.ts",
    
    "seed:questions": "tsx prisma/seed-questions.ts",
    "seed:e2e": "tsx prisma/seed-e2e.ts",
    "sync:questions": "tsx src/scripts/syncQuestions.ts"
  },
  "dependencies": {
    "@epochstudio/content-client": "^0.0.1",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "nodemailer": "^8.0.10",
    "prisma": "^6.19.3",
    "winston": "^3.17.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.0": true,
    "fsevents@2.3.3": true,
    "prisma@6.19.3": true
  }
}
