# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ─── Database (MySQL) ────────────────────────────────────────
# Prisma reads this single URL. Format:
#   mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root@localhost:3306/epoch_quiz"

# The app itself uses only DATABASE_URL (via Prisma). These discrete vars are
# for docker-compose, which uses them to provision the MySQL container and to
# build DATABASE_URL. Keep them in sync with DATABASE_URL above.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=epoch_quiz

# ─── JWT (used from Module 3 onward) ─────────────────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Security ────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
CORS_ORIGIN=http://localhost:5173

# ─── Rate limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Email (SMTP — required for password reset emails in production) ──
# Leave blank in development: reset tokens are returned in API responses instead.
# For production use any SMTP provider (Gmail, SendGrid, Mailgun, Postmark…)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=Epoch Quiz <noreply@yourschool.edu>
APP_URL=https://your-production-domain.com
# Recipient of the "Contact us" form. Defaults to a hardcoded address in
# code (src/config/env.ts) if unset — override here instead of relying on it.
CONTACT_TO=contact@yourschool.edu

# ─── Seed (used by `npm run prisma:seed` to create initial admin) ─
SEED_ADMIN_EMAIL=admin@epoch.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Publication Admin

# ─── Epoch Content API (catalog: boards/classes/subjects/series/books/chapters) ─
# The Content API is the SINGLE SOURCE OF TRUTH for catalog metadata. The backend
# fetches it live (with a short TTL cache) and NEVER mirrors catalog data into
# MySQL — there is no catalog sync job, no manual catalog sync endpoint, no
# write-through. Leave the key blank to run without live catalog (catalog
# endpoints return empty; server still boots).
CONTENT_API_KEY=default-api-key-123456
CONTENT_BASE_URL=https://content.epochgpt.in
# Optional DNS pin: connect to this IP while keeping TLS SNI + Host = the
# CONTENT_BASE_URL host. Leave blank unless the host can't be resolved locally.
CONTENT_RESOLVE_IP=
CONTENT_HTTP_TIMEOUT_MS=20000
CONTENT_MAX_RETRIES=3
# Short-lived in-memory cache for Content API responses (ms). Never a mirror.
CONTENT_CACHE_TTL_MS=300000
# Page size for `npm run sync:questions` (imports Question rows from the
# Content API into MySQL — the only data pulled from Content API into MySQL).
CONTENT_SYNC_PAGE_SIZE=100
