generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model OlympiadMode {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  serial    String?
  kind      String     @default("OLYMPIAD")
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("olympiad_modes")
}

model User {
  id                         String                      @id @default(cuid())
  email                      String                      @unique
  mobileNo                   String?                     @unique
  passwordHash               String
  name                       String
  role                       Role
  status                     UserStatus                  @default(ACTIVE)
  avatarHue                  Int                         @default(180)
  profileComplete            Boolean                     @default(false)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  assessmentAssignedStudents AssessmentAssignedStudent[]
  createdAssessments         Assessment[]                @relation("AssessmentCreatedBy")
  questionUploads            QuestionUpload[]            @relation("UploaderQuestions")
  createdQuestions           Question[]                  @relation("QuestionCreatedBy")
  createdAssessmentQuestions AssessmentQuestionBank[]    @relation("AssessmentQuestionCreatedBy")
  quizAssignedStudents       QuizAssignedStudent[]
  quizAttempts               QuizAttempt[]               @relation("StudentAttempts")
  createdQuizzes             Quiz[]                      @relation("QuizCreatedBy")
  refreshTokens              RefreshToken[]
  studentProfile             StudentProfile?
  submissions                Submission[]
  teacherProfile             TeacherProfile?

  @@index([role])
  @@index([status])
  @@map("users")
}

model TeacherProfile {
  id              String           @id @default(cuid())
  userId          String           @unique
  mobileNo        String?
  dob             DateTime?
  schoolName      String?
  educationBoard  String?
  stateBoard      String?
  teacherCode     String?          @unique
  address         String?          @db.Text
  country         String?
  state           String?
  city            String?
  zip             String?
  imageUrl        String?          @db.MediumText
  bio             String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  boardExternalId String?
  books           TeacherBook[]
  classes         TeacherClass[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherSeries   TeacherSeries[]
  subjects        TeacherSubject[]

  @@index([boardExternalId])
  @@map("teacher_profiles")
}

model StudentProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  mobileNo         String?
  dob              DateTime?
  schoolName       String?
  educationBoard   String?
  stateBoard       String?
  teacherCode      String?
  address          String?          @db.Text
  country          String?
  state            String?
  city             String?
  zip              String?
  imageUrl         String?          @db.MediumText
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  boardExternalId  String?
  classExternalId  String?
  seriesExternalId String?
  books            StudentBook[]
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects         StudentSubject[]

  @@index([boardExternalId])
  @@index([classExternalId])
  @@index([seriesExternalId])
  @@map("student_profiles")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model StudentBook {
  studentProfileId String
  bookExternalId   String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@id([studentProfileId, bookExternalId])
  @@index([bookExternalId])
  @@map("student_books")
}

model TeacherClass {
  teacherProfileId String
  classExternalId  String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  @@id([teacherProfileId, classExternalId])
  @@index([classExternalId])
  @@map("teacher_classes")
}

model TeacherSubject {
  teacherProfileId  String
  subjectExternalId String
  teacherProfile    TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  @@id([teacherProfileId, subjectExternalId])
  @@index([subjectExternalId])
  @@map("teacher_subjects")
}

model TeacherSeries {
  teacherProfileId String
  seriesExternalId String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  @@id([teacherProfileId, seriesExternalId])
  @@index([seriesExternalId])
  @@map("teacher_series")
}

model TeacherBook {
  teacherProfileId String
  bookExternalId   String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  @@id([teacherProfileId, bookExternalId])
  @@index([bookExternalId])
  @@map("teacher_books")
}

model StudentSubject {
  studentProfileId  String
  subjectExternalId String
  studentProfile    StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@id([studentProfileId, subjectExternalId])
  @@index([subjectExternalId])
  @@map("student_subjects")
}

model Question {
  id                  String               @id @default(cuid())
  type                QuestionType
  prompt              String               @db.Text
  promptImageUrl      String?
  optionA             String?              @db.Text
  optionAImageUrl     String?
  optionB             String?              @db.Text
  optionBImageUrl     String?
  optionC             String?              @db.Text
  optionCImageUrl     String?
  optionD             String?              @db.Text
  optionDImageUrl     String?
  correctAnswer       String?
  correctOptions      String               @db.LongText
  correctBoolean      Boolean?
  modelAnswer         String?              @db.Text
  matchPairs          String?              @db.LongText
  explanation         String?              @db.Text
  explanationImageUrl String?
  marks               Int                  @default(1)
  negativeMarks       Float                @default(0)
  difficulty          Difficulty           @default(MEDIUM)
  language            String?              @default("English")
  educationBoard      String?
  tags                String               @db.LongText
  status              UserStatus           @default(ACTIVE)
  createdById         String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  subjectExternalId   String?
  classExternalId     String?
  bookExternalId      String?
  chapterExternalId   String?
  externalId          String?              @unique
  attemptAnswers      AttemptAnswer[]
  createdBy           User                 @relation("QuestionCreatedBy", fields: [createdById], references: [id])
  quizQuestions       QuizQuestion[]

  @@index([createdById])
  @@index([type])
  @@index([subjectExternalId])
  @@index([difficulty])
  @@index([bookExternalId])
  @@index([chapterExternalId])
  @@index([classExternalId])
  @@map("questions")
}

// Assessment's own question-content table — deliberately a full duplicate of
// Question's shape rather than a shared table with a filter, so it is
// structurally impossible for Practice/Olympiad (which only ever queries
// `Question`) to surface an assessment question, or vice versa. No
// `externalId`/sync support: assessment questions are admin-authored, never
// synced from the external content catalog (that pipeline is Practice-only).
model AssessmentQuestionBank {
  id                  String               @id @default(cuid())
  type                QuestionType
  prompt              String               @db.Text
  promptImageUrl      String?
  optionA             String?              @db.Text
  optionAImageUrl     String?
  optionB             String?              @db.Text
  optionBImageUrl     String?
  optionC             String?              @db.Text
  optionCImageUrl     String?
  optionD             String?              @db.Text
  optionDImageUrl     String?
  correctAnswer       String?
  correctOptions      String               @db.LongText
  correctBoolean      Boolean?
  modelAnswer         String?              @db.Text
  matchPairs          String?              @db.LongText
  explanation         String?              @db.Text
  explanationImageUrl String?
  marks               Int                  @default(1)
  negativeMarks       Float                @default(0)
  difficulty          Difficulty           @default(MEDIUM)
  language            String?              @default("English")
  educationBoard      String?
  tags                String               @db.LongText
  status              UserStatus           @default(ACTIVE)
  createdById         String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  subjectExternalId   String?
  classExternalId     String?
  bookExternalId      String?
  chapterExternalId   String?
  answers             Answer[]
  assessmentLinks     AssessmentQuestion[]
  createdBy           User                 @relation("AssessmentQuestionCreatedBy", fields: [createdById], references: [id])

  @@index([createdById])
  @@index([type])
  @@index([subjectExternalId])
  @@index([difficulty])
  @@map("assessment_question_bank")
}

model Assessment {
  id                 String            @id @default(cuid())
  title              String
  description        String?           @db.Text
  questionSelection  QuestionSelection @default(MANUAL)
  totalQuestions     Int               @default(0)
  duration           Int               @default(60)
  totalMarks         Int               @default(0)
  passingMarks       Int               @default(0)
  // Enforced end-to-end: validator (assessment.validator.ts), set on
  // create/update (AssessmentService), and applied during grading
  // (gradeAnswer/wrongAnswerPenalty in submission.service.ts) — a wrong,
  // attempted answer is docked negativeMarksValue marks; skipped questions
  // are never penalized; a submission's total score floors at 0.
  negativeMarking    Boolean           @default(false)
  negativeMarksValue Float             @default(0)
  status             AssessmentStatus  @default(DRAFT)
  publishedAt        DateTime?
  // Shown to the student on the pre-start Assessment Overview screen
  // (falls back to a generic instruction list client-side when null).
  instructions       String?           @db.Text
  // Result-visibility gating: a student's own submission/result data is
  // withheld (server-side, not just UI) until either of these fires — see
  // AssessmentService.isResultVisible / SubmissionService.
  resultsPublished   Boolean           @default(false)
  resultPublishAt    DateTime?
  createdById        String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  classExternalId    String?
  subjectExternalId  String?

  // ── Reserved for future functionality ──────────────────────────────────
  // Set nowhere in AssessmentService.create/update, read nowhere — every
  // assessment sits at these defaults forever. Real, plausible
  // configuration (assessment type, shuffling, a scheduling window, etc.),
  // not dead scaffolding: keep the column, add the enforcement + admin/
  // teacher UI together, and move a field out of this block in the same
  // change that makes it do something. (Mirrors the equivalent block on
  // the Quiz model.)
  assessmentType   AssessmentType  @default(CHAPTER_TEST)
  shuffleQuestions Boolean         @default(false)
  showResultAfter  ShowResultAfter @default(IMMEDIATELY)
  showExplanation  Boolean         @default(true)
  language         String?         @default("English")
  bannerImageUrl   String?
  startDatetime    DateTime?
  endDatetime      DateTime?
  // ─────────────────────────────────────────────────────────────────────

  assignedClasses  AssessmentAssignedClass[]
  assignedStudents AssessmentAssignedStudent[]
  chapters         AssessmentChapter[]
  questions        AssessmentQuestion[]
  createdBy        User                        @relation("AssessmentCreatedBy", fields: [createdById], references: [id])
  questionUploads  QuestionUpload[]
  submissions      Submission[]

  @@index([createdById])
  @@index([status])
  @@index([subjectExternalId])
  @@index([classExternalId])
  @@map("assessments")
}

model AssessmentQuestion {
  id               String     @id @default(cuid())
  assessmentId     String
  questionId       String
  order            Int
  marksOverride    Float?
  negMarksOverride Float?
  assessment       Assessment             @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question         AssessmentQuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@unique([assessmentId, order])
  @@index([assessmentId])
  @@index([questionId])
  @@map("assessment_questions")
}

// Reserved for future functionality: chapter-scoping an assessment's
// question pool. Nothing creates or reads a row here — AssessmentService
// never writes to this table on create/update, and question selection for
// an assessment goes entirely through AssessmentQuestion (an explicit,
// admin/teacher-picked list) instead. Real, plausible feature (e.g. "pull
// N questions from these chapters" as an alternative to hand-picking every
// question), not dead scaffolding — wire it up (validator, service, UI)
// before writing to it, don't resurrect it partially.
model AssessmentChapter {
  assessmentId      String
  chapterExternalId String
  assessment        Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@id([assessmentId, chapterExternalId])
  @@index([chapterExternalId])
  @@map("assessment_chapters")
}

model AssessmentAssignedClass {
  assessmentId    String
  classExternalId String
  assessment      Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@id([assessmentId, classExternalId])
  @@index([classExternalId])
  @@map("assessment_assigned_classes")
}

model AssessmentAssignedStudent {
  assessmentId String
  studentId    String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([assessmentId, studentId])
  @@index([studentId], map: "assessment_assigned_students_studentId_fkey")
  @@map("assessment_assigned_students")
}

model Submission {
  id           String           @id @default(cuid())
  assessmentId String
  studentId    String
  status       SubmissionStatus @default(IN_PROGRESS)
  // Float, not Int: marks can be fractional (AssessmentQuestion.marksOverride
  // is Float, and negative marking can deduct fractional values) — matches
  // QuizAttempt.score, the equivalent field on the Practice/Olympiad side.
  score        Float            @default(0)
  totalMarks   Float            @default(0)
  startedAt    DateTime         @default(now())
  submittedAt  DateTime?
  timeTakenSec Int              @default(0)
  answers      Answer[]
  assessment   Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student      User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, studentId])
  @@index([studentId])
  @@index([assessmentId])
  @@index([status])
  @@map("submissions")
}

model Answer {
  id              String     @id @default(cuid())
  submissionId    String
  questionId      String
  selectedOption  Int?
  selectedBoolean Boolean?
  textAnswer      String?    @db.Text
  isCorrect       Boolean?
  // Float: can be negative (negative marking) or fractional (marksOverride).
  marksAwarded    Float      @default(0)
  timeMs          Int?
  selectedOptions String                 @db.LongText
  question        AssessmentQuestionBank @relation(fields: [questionId], references: [id])
  submission      Submission             @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@index([questionId])
  @@map("answers")
}

model Quiz {
  id                String            @id @default(cuid())
  title             String
  description       String?           @db.Text
  quizType          QuizType          @default(PRACTICE)
  questionSelection QuestionSelection @default(MANUAL)
  totalQuestions    Int               @default(0)
  totalMarks        Int               @default(0)
  duration          Int               @default(0)
  language          String?           @default("English")
  status            QuizStatus        @default(DRAFT)

  // ── Reserved for future functionality ──────────────────────────────────
  // Practice/Olympiad quizzes are created lazily (getOrCreatePracticeQuiz /
  // getOrCreateOlympiadQuiz in quiz.service.ts) and never set any field
  // below beyond its default — nothing in the app reads them yet. They are
  // real, planned configuration (attempt caps, negative marking, a
  // scheduling window, etc.), not dead scaffolding: keep the column, add
  // the enforcement + admin UI together, and move a field out of this
  // block in the same change that makes it do something.
  negativeMarking    Boolean               @default(false)
  negativeMarksValue Float                 @default(0)
  startDatetime      DateTime?
  endDatetime        DateTime?
  passingMarks       Int                   @default(0)
  maxAttempts        Int?
  shuffleQuestions   Boolean               @default(false)
  shuffleOptions     Boolean               @default(false)
  showResultAfter    ShowResultAfter       @default(IMMEDIATELY)
  showExplanation    Boolean               @default(true)
  certificateEnabled Boolean               @default(false)
  leaderboardEnabled Boolean               @default(true)
  instructions       String?               @db.Text
  bannerImageUrl     String?
  // ─────────────────────────────────────────────────────────────────────
  createdById        String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  boardExternalId    String?
  bookExternalId     String?
  classExternalId    String?
  seriesExternalId   String?
  subjectExternalId  String?
  questionUploads    QuestionUpload[]
  assignedClasses    QuizAssignedClass[]
  assignedStudents   QuizAssignedStudent[]
  attempts           QuizAttempt[]
  chapters           QuizChapter[]
  questions          QuizQuestion[]
  createdBy          User                  @relation("QuizCreatedBy", fields: [createdById], references: [id])

  @@index([createdById])
  @@index([status])
  @@index([classExternalId])
  @@index([boardExternalId])
  @@index([bookExternalId])
  @@index([seriesExternalId])
  @@index([subjectExternalId])
  @@map("quizzes")
}

// ── Reserved for future functionality ────────────────────────────────────
// QuizQuestion / QuizChapter / QuizAssignedClass / QuizAssignedStudent are
// unused by every Quiz row that exists today. Quiz rows are only ever
// created by two lazy-singleton helpers (getOrCreatePracticeQuiz /
// getOrCreateOlympiadQuiz in quiz.service.ts), and both hardcode
// questionSelection: 'AUTO_RANDOM' — no code path in the app ever creates
// a Quiz with questionSelection: MANUAL, which is the mode these tables
// exist to support. Practice/Olympiad quizzes instead pick questions
// dynamically per attempt straight from Question (scoped by subject/class/
// board) and are open to any eligible student, not explicitly assigned.
//
// This is real, planned configuration — a manually-built, explicitly-
// assigned Quiz, mirroring how Assessment + AssessmentQuestion +
// AssessmentAssignedClass/Student already work for Assessments — not
// abandoned scaffolding. Build the MANUAL creation path (validator,
// service, admin/teacher UI) before writing to these tables; don't wire up
// a partial version.
model QuizQuestion {
  id               String   @id @default(cuid())
  quizId           String
  questionId       String
  sortOrder        Int      @default(0)
  marksOverride    Float?
  negMarksOverride Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  question         Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  quiz             Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionId])
  @@index([quizId])
  @@index([questionId])
  @@map("quiz_questions")
}

model QuizChapter {
  quizId            String
  chapterExternalId String
  quiz              Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@id([quizId, chapterExternalId])
  @@index([chapterExternalId])
  @@map("quiz_chapters")
}

model QuizAssignedClass {
  quizId          String
  classExternalId String
  quiz            Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@id([quizId, classExternalId])
  @@index([classExternalId])
  @@map("quiz_assigned_classes")
}

model QuizAssignedStudent {
  quizId    String
  studentId String
  quiz      Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([quizId, studentId])
  @@index([studentId], map: "quiz_assigned_students_studentId_fkey")
  @@map("quiz_assigned_students")
}

// ───────────────────────────────────────────────────────────────────────

model QuizAttempt {
  id                   String          @id @default(cuid())
  quizId               String
  studentId            String
  attemptNumber        Int
  startTime            DateTime        @default(now())
  endTime              DateTime?
  timeTakenSec         Int             @default(0)
  /// Server-assigned time budget for this attempt (Subject Practice: from
  /// PracticeConfig by difficulty). Null for attempt types with no time cap
  /// (e.g. Olympiad, or legacy attempts predating this field).
  timeLimitSec         Int?
  score                Float           @default(0)
  correctAnswers       Int             @default(0)
  wrongAnswers         Int             @default(0)
  skipped              Int             @default(0)
  percentage           Float           @default(0)
  rank                 Int?
  isPassed             Boolean?
  certificateUrl       String?
  isSubmitted          Boolean         @default(false)
  status               AttemptStatus   @default(IN_PROGRESS)
  // ── Pause / resume — same scheme as Submission (see comment there) ──────
  currentQuestionIndex Int             @default(0)
  pausedAt             DateTime?
  totalPausedSec       Int             @default(0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  answers              AttemptAnswer[]
  quiz                 Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student              User            @relation("StudentAttempts", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([quizId, studentId, attemptNumber])
  @@index([quizId])
  @@index([studentId])
  @@index([status])
  @@map("quiz_attempts")
}

model AttemptAnswer {
  id                   String      @id @default(cuid())
  attemptId            String
  questionId           String
  selectedOption       String?
  selectedOptions      String      @db.LongText
  textAnswer           String?     @db.Text
  isCorrect            Boolean?
  marksAwarded         Float       @default(0)
  timeSpentSec         Int?
  isSkipped            Boolean     @default(false)
  isMarkedReview       Boolean     @default(false)
  // ── Pause / resume draft ─────────────────────────────────────────────
  // A question is submitted (locked, graded) exactly once via saveAnswer,
  // which sets isSubmitted true and clears these draft columns. Until then,
  // a selection the student made but hasn't locked in yet is persisted here
  // by the debounced progress-autosave / explicit Pause, so it survives a
  // refresh or pause/resume without affecting grading.
  isSubmitted          Boolean     @default(false)
  draftSelectedOption  String?
  draftSelectedOptions String?     @db.LongText
  draftTextAnswer      String?     @db.Text
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  attempt              QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question             Question    @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("attempt_answers")
}

// "otpCode" is a 64-char crypto.randomBytes(32) hex token for the
// password-reset email link, not a guessable numeric code — brute-forcing
// it is computationally infeasible, so there is no per-record attempt
// counter here. The /reset-password route already carries a per-IP rate
// limiter (auth.routes.ts) as its brute-force defense.
model Otp {
  id            String   @id @default(cuid())
  mobileOrEmail String
  otpCode       String
  otpType       OtpType
  expiresAt     DateTime
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([mobileOrEmail])
  @@index([otpType])
  @@map("otps")
}

model QuestionUpload {
  id           String       @id @default(cuid())
  uploadedById String
  quizId       String?
  assessmentId String?
  uploadStatus UploadStatus @default(PENDING)
  totalRows    Int          @default(0)
  rowsImported Int          @default(0)
  rowsFailed   Int          @default(0)
  errorLog     String?      @db.LongText
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  assessment   Assessment?  @relation(fields: [assessmentId], references: [id])
  quiz         Quiz?        @relation(fields: [quizId], references: [id])
  uploadedBy   User         @relation("UploaderQuestions", fields: [uploadedById], references: [id])

  @@index([uploadedById])
  @@index([quizId])
  @@index([assessmentId])
  @@map("question_uploads")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  category  String   @default("general")
  label     String   @default("")
  type      String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("settings")
}

enum Role {
  SUPER_ADMIN
  PUBLICATION_ADMIN
  CONTENT_MANAGER
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  PENDING
  INACTIVE
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTIPLE
  TRUE_FALSE
  FILL_IN_BLANK
  MATCH_THE_COLUMN
  DESCRIPTIVE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum AssessmentType {
  OLYMPIAD
  CHAPTER_TEST
  MOCK_TEST
  PRACTICE
  ASSIGNMENT
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionSelection {
  MANUAL
  AUTO_RANDOM
  AUTO_LEVEL
}

enum ShowResultAfter {
  IMMEDIATELY
  AFTER_END_DATE
  MANUALLY
}

enum QuizType {
  PRACTICE
  OLYMPIAD
  CHAPTER_TEST
  MOCK_TEST
  LIVE_QUIZ
  ASSIGNMENT
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  ABANDONED
}

// Only PASSWORD_RESET exists as a real flow — registration and login are
// plain email+password (no OTP step), and there is no phone-verification
// feature. Kept as an enum (rather than dropped in favor of a plain
// string) so a genuinely new OTP-gated flow can add a value here later.
enum OtpType {
  PASSWORD_RESET
}

enum UploadStatus {
  PENDING
  SUCCESS
  // Some rows imported, some failed validation — distinct from FAILED
  // (nothing imported) so upload history can tell the two apart.
  PARTIAL
  FAILED
}
