# Copy to `.env` and fill in real values before `docker compose up`.
# docker-compose.yml reads these. NEVER commit the real .env.

# ── Public origin (used for CORS allow-list + password-reset links) ──
APP_URL=https://quiz.example.com
WEB_PORT=80

# ── Database ──────────────────────────────────────────────────────────
# Strong password required — this is the MySQL root password.
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=epoch_quiz

# ── JWT secrets (min 16 chars each; generate with `openssl rand -hex 32`) ─
JWT_ACCESS_SECRET=change-me-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-different-openssl-rand-hex-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Security / limits ─────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
LOG_LEVEL=info

# ── Email (optional — leave SMTP_* blank to disable real delivery) ────
EMAIL_FROM=Epoch Quiz <noreply@epochquiz.app>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO=

# ── Epoch Content API (catalog source of truth; never mirrored to MySQL) ──
# Blank = catalog endpoints return empty (server still boots).
CONTENT_API_KEY=
CONTENT_BASE_URL=https://content.epochgpt.in
CONTENT_CACHE_TTL_MS=300000
